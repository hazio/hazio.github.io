---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pieces = [
  {
    slug: "electrical-circuit-model",
    title: "SRF Electrical Circuit Model",
    subtitle: "Psychological Regulation as an Electrical Circuit",
    image: "/artwork/electrical-circuit-model.png",
  },
  {
    slug: "binary-world",
    title: "The Binary World",
    subtitle: "Splitting as a Compression Algorithm",
    image: "/artwork/creation-of-adam.png",
  },
];
---

<BaseLayout
  title="Artwork"
  description="Visual explorations of the Structural Regulation Framework — diagrams, models, and conceptual art."
>
  <section class="hero">
    <div class="kicker">Visual Thinking</div>
    <h1>Artwork</h1>
    <p class="sub">
      Conceptual diagrams and visual models exploring the Structural Regulation Framework.
      Each piece is accompanied by a detailed explanation.
    </p>
  </section>

  <section class="grid">
    {pieces.map((piece) => (
      <a class="card" href={`/artwork/${piece.slug}/`}>
        <div class="card-image">
          <img src={piece.image} alt={piece.title} loading="lazy" />
        </div>
        <div class="card-body">
          <h2 class="title">{piece.title}</h2>
          <p class="desc">{piece.subtitle}</p>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 18px 0 16px;
    border-bottom: 1px solid rgba(255,255,255,0.10);
    margin-bottom: 24px;
  }

  .kicker {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-secondary);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 14px 0 6px;
    font-size: 40px;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .sub {
    margin: 0;
    color: var(--text-secondary);
    max-width: 70ch;
    font-size: 16px;
    line-height: 1.55;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .card {
    border-radius: 18px;
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.12s ease, background 0.12s ease, border-color 0.12s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    background: var(--panel);
    border-color: var(--border-hover);
  }

  .card-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #fff;
    border-bottom: 1px solid var(--border);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    padding: 16px 18px 20px;
  }

  .title {
    margin: 0 0 6px;
    font-size: 17px;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .card:hover .title {
    text-decoration: underline;
  }

  .desc {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }

  @media (max-width: 700px) {
    .grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 34px;
    }
  }
</style>
