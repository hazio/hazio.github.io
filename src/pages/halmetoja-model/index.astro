---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getCollection, getEntry, render } from "astro:content";

const entry = await getEntry("halmetoja-model", "index");
const { Content } = await render(entry);

const nav = (await getCollection("halmetoja-model"))
  .map((e) => ({ slug: e.id, title: e.data.title }))
  .sort((a, b) => a.slug.localeCompare(b.slug));
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  nav={nav}
  currentSlug={"index"}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": entry.data.title,
      ...(entry.data.description && { "description": entry.data.description }),
      "url": "https://halmetojamodel.com/halmetoja-model/",
      "author": { "@type": "Person", "name": "Jani Halmetoja" },
      "publisher": { "@type": "Organization", "name": "Halmetoja Model" }
    })} />
  </Fragment>
  <Content />
</DocsLayout>