---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles", ({ data }) => !data.draft);

// Uusin ensin
articles.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});
---

<BaseLayout 
  title="Articles — Halmetoja Model"
  description="Long-form articles exploring narcissism, empathy, identity formation, relational asymmetry, and regulatory psychology."
>

  <main class="articles">

    <header class="articles-hero">
      <h1>Articles</h1>
      <p>
        Structural explorations of regulation, identity, and relational dynamics.
      </p>
    </header>

    <section class="articles-grid">
      {articles.map((article) => (
        <a class="article-card" href={`/articles/${article.slug}/`}>
          <div class="card-top">
            <h2>{article.data.title}</h2>
            {article.data.date && (
              <time datetime={article.data.date.toISOString()}>
                {article.data.date.toLocaleDateString()}
              </time>
            )}
          </div>

          <p class="description">
            {article.data.description}
          </p>

          {article.data.tags?.length > 0 && (
            <div class="tags">
              {article.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </section>

  </main>

</BaseLayout>

<style>
  .articles {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .articles-hero {
    margin-bottom: 3rem;
  }

  .articles-hero h1 {
    margin-bottom: 0.5rem;
  }

  .articles-hero p {
    color: var(--muted);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .article-card {
    display: block;
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    transition: transform 0.15s ease, border-color 0.15s ease;
    color: inherit;
  }

  .article-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }

  .card-top {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: 1rem;
  }

  .card-top time {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .description {
    line-height: 1.6;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--muted);
  }
</style>