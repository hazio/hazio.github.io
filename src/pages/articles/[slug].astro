---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles
    .filter((a) => !a.data.draft)
    .map((article) => ({
      params: { slug: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": article.data.title,
      "description": article.data.description,
      "url": `https://halmetojamodel.com/articles/${article.id}/`,
      ...(article.data.date && { "datePublished": article.data.date.toISOString() }),
      "author": { "@type": "Person", "name": "Jani Halmetoja" },
      "publisher": { "@type": "Organization", "name": "Halmetoja Model" }
    })} />
  </Fragment>

  <main class="article">
    <article>

      <header class="article-header">
        <h1>{article.data.title}</h1>
        {article.data.date && (
          <time datetime={article.data.date.toISOString()}>
            {article.data.date.toDateString()}
          </time>
        )}
      </header>

      <Content />

      <footer class="article-footer">
        <hr />
        <p>
          Explore more in the <a href="/halmetoja-model/">Halmetoja Model framework</a>.
        </p>
      </footer>

    </article>
  </main>

</BaseLayout>

<style>
  .article {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  h1 {
    margin-bottom: 1rem;
  }

  h2 {
    margin-top: 2.5rem;
  }

  p, li {
    line-height: 1.7;
  }

  ul {
    margin-left: 1.2rem;
  }

  .article-header time {
    display: block;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .article-footer {
    margin-top: 3rem;
    font-size: 0.95rem;
  }

  hr {
    margin: 2rem 0;
    opacity: 0.2;
  }
</style>