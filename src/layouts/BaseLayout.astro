---
// Jos sinulla on jo propsit täällä, pidä ne.
// Lisään vain oletuksena description-tuen:
const { title = "Halmetoja Model", description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root{
    --bg: #0b0d12;
    --text: #e9edf5;
    --muted: #a9b2c3;
    --border: rgba(255,255,255,.10);
    --accent: #7aa2ff;

    --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    --sans: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
  }

  body{
    margin:0;
    font-family: var(--sans);
    background: radial-gradient(1200px 900px at 15% 0%, rgba(122,162,255,.10), transparent 60%),
                radial-gradient(900px 700px at 100% 0%, rgba(255,255,255,.06), transparent 55%),
                var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  a{ color: var(--accent); }
  a:hover{ filter: brightness(1.06); }

  /* --- “Prose” typography --- */
  .prose{
    max-width: 72ch;
    line-height: 1.65;
    font-size: 1.04rem;
  }

  .prose h1, .prose h2, .prose h3{
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 1.9rem 0 0.7rem;
  }
  .prose h1{ font-size: 2.05rem; margin-top: 0; }
  .prose h2{ font-size: 1.5rem; }
  .prose h3{ font-size: 1.15rem; color: var(--text); opacity: .95; }

  .prose p{ margin: 0.85rem 0; color: color-mix(in srgb, var(--text) 92%, var(--muted) 8%); }
  .prose strong{ color: var(--text); }
  .prose em{ color: color-mix(in srgb, var(--text) 84%, var(--muted) 16%); }

  .prose ul, .prose ol{ padding-left: 1.1rem; margin: 0.85rem 0; }
  .prose li{ margin: 0.35rem 0; }
  .prose hr{
    border: 0;
    border-top: 1px solid var(--border);
    margin: 1.6rem 0;
  }

  .prose blockquote{
    margin: 1.1rem 0;
    padding: 0.9rem 1rem;
    border-left: 3px solid color-mix(in srgb, var(--accent) 55%, transparent 45%);
    background: color-mix(in srgb, var(--bg) 92%, #fff 8%);
    border-radius: 12px;
    color: color-mix(in srgb, var(--text) 86%, var(--muted) 14%);
  }

  .prose code{
    font-family: var(--mono);
    font-size: 0.93em;
    background: rgba(255,255,255,.06);
    padding: 0.12em 0.35em;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .prose pre{
    background: rgba(255,255,255,.06);
    border: 1px solid var(--border);
    padding: 0.95rem 1rem;
    border-radius: 14px;
    overflow:auto;
  }
  .prose pre code{
    background: transparent;
    border: 0;
    padding: 0;
    font-size: 0.92em;
  }

  .prose table{
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }
  .prose th, .prose td{
    padding: 0.6rem 0.7rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .prose th{
    text-align: left;
    color: var(--text);
    background: rgba(255,255,255,.05);
  }
</style>