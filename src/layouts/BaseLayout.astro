---
const nav = [
  { label: "Framework", href: "/halmetoja-model/" },
  { label: "Articles", href: "/articles/" },
  { label: "Projects", href: "/projects/" },
];

// Muokkaa nämä sun oikeisiin osoitteisiin:
const links = {
  substack: "https://halmetojamodel.substack.com/",
  youtube: "https://www.youtube.com/@halmetojamodel"
};

const path = Astro.url.pathname;
const isActive = (href) => path.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <link rel="shortcut icon" href="/favicon.jpg" />
    <link rel="apple-touch-icon" href="/favicon.jpg" />
    
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4ELBRBNM68"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-4ELBRBNM68');
    </script>
    
    <slot name="head" />
    <style>
      :root {
        --bg: #0b0b0f;
        --panel: rgba(255, 255, 255, 0.06);
        --panel2: rgba(255, 255, 255, 0.10);
        --text: rgba(255, 255, 255, 0.92);
        --muted: rgba(255, 255, 255, 0.70);
        --line: rgba(255, 255, 255, 0.10);
        --shadow: 0 18px 60px rgba(0,0,0,0.45);
      }
      body {
        margin: 0;
        background: radial-gradient(1200px 600px at 10% -10%, rgba(255,255,255,0.08), transparent 60%),
                    radial-gradient(900px 500px at 90% 0%, rgba(255,255,255,0.06), transparent 55%),
                    var(--bg);
        color: var(--text);
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
      }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: 1120px; margin: 0 auto; padding: 0 18px; }

      /* Premium header */
      .hdr {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--line);
        background: rgba(11,11,15,0.55);
      }
      .hdr-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .brand {
        display: inline-flex;
        gap: 10px;
        align-items: center;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 650;
        font-size: 12px;
      }
      .logo-img {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid rgba(255,255,255,0.25);
      }
      .nav {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .nav a {
        padding: 9px 12px;
        border-radius: 12px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1;
        border: 1px solid transparent;
      }
      .nav a:hover {
        color: var(--text);
        background: var(--panel);
        border-color: rgba(255,255,255,0.10);
      }
      .nav a[aria-current="page"] {
        color: var(--text);
        background: var(--panel2);
        border-color: rgba(255,255,255,0.14);
      }

      .right {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .iconbar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px;
        border-radius: 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.10);
      }
      .iconbtn {
        width: 34px; height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        border: 1px solid transparent;
        background: transparent;
        color: var(--muted);
      }
      .iconbtn:hover {
        color: var(--text);
        background: rgba(255,255,255,0.06);
        border-color: rgba(255,255,255,0.10);
      }
      .hamburger {
        display: none;
        width: 38px; height: 38px;
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.04);
        color: var(--text);
        align-items: center;
        justify-content: center;
      }
      .hamburger:hover { background: rgba(255,255,255,0.06); }

      /* Mobile menu */
      .mnav {
        display: none;
        border-top: 1px solid var(--line);
        padding: 12px 0 14px;
      }
      .mnav a {
        display: block;
        padding: 12px 14px;
        border-radius: 14px;
        color: var(--muted);
        border: 1px solid transparent;
      }
      .mnav a:hover {
        color: var(--text);
        background: var(--panel);
        border-color: rgba(255,255,255,0.10);
      }
      .micons { display: flex; gap: 10px; padding: 10px 8px 0; }

      /* Responsive */
      @media (max-width: 860px) {
        .nav { display: none; }
        .hamburger { display: inline-flex; }
      }
    </style>
  </head>

  <body>
    <header class="hdr">
      <div class="wrap">
        <div class="hdr-inner">
          <a class="brand" href="/">
            <img 
              src="/channels4_profile.jpg" 
              alt="Halmetoja Model" 
              class="logo-img" 
            />
            <span>Halmetoja Model</span>
          </a>

          <nav class="nav" aria-label="Primary">
            {nav.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </nav>

          <div class="right">
            <div class="iconbar" aria-label="External links">
              <a class="iconbtn" href={links.substack} target="_blank" rel="noopener noreferrer" aria-label="Substack">
                <!-- Substack-ish icon -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M5 4h14v4H5V4Z" stroke="currentColor" stroke-width="2"/>
                  <path d="M5 10h14v10l-7-4-7 4V10Z" stroke="currentColor" stroke-width="2"/>
                </svg>
              </a>
              <a class="iconbtn" href={links.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <path d="M10 8.5v7l6-3.5-6-3.5Z" fill="currentColor"/>
                  <path d="M21 12c0-3.5-.4-5.4-1-6-1-.9-5-.9-8-.9s-7 0-8 .9c-.6.6-1 2.5-1 6s.4 5.4 1 6c1 .9 5 .9 8 .9s7 0 8-.9c.6-.6 1-2.5 1-6Z"
                        stroke="currentColor" stroke-width="2"/>
                </svg>
              </a>
            </div>

            <button class="hamburger" type="button" aria-label="Open menu" aria-expanded="false" data-menu-btn>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M5 7h14M5 12h14M5 17h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        </div>

        <nav class="mnav" aria-label="Mobile" data-menu>
          {nav.map((item) => (
            <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          ))}
          <div class="micons">
            <a class="iconbtn" href={links.substack} target="_blank" rel="noopener noreferrer" aria-label="Substack">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M5 4h14v4H5V4Z" stroke="currentColor" stroke-width="2"/>
                <path d="M5 10h14v10l-7-4-7 4V10Z" stroke="currentColor" stroke-width="2"/>
              </svg>
            </a>
            <a class="iconbtn" href={links.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M10 8.5v7l6-3.5-6-3.5Z" fill="currentColor"/>
                <path d="M21 12c0-3.5-.4-5.4-1-6-1-.9-5-.9-8-.9s-7 0-8 .9c-.6.6-1 2.5-1 6s.4 5.4 1 6c1 .9 5 .9 8 .9s7 0 8-.9c.6-.6 1-2.5 1-6Z"
                      stroke="currentColor" stroke-width="2"/>
              </svg>
            </a>
            <a class="iconbtn" href={links.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M12 2C6.5 2 2 6.6 2 12.2c0 4.5 2.9 8.3 6.9 9.6.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.5-1.3-1.1-1.6-1.1-1.6-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.4 1.1 3 .8.1-.7.4-1.1.7-1.4-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.2 9.2 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.7-4.7 5 .4.3.7 1 .7 2v3c0 .3.2.6.7.5 4-1.3 6.9-5.1 6.9-9.6C22 6.6 17.5 2 12 2Z"
                      fill="currentColor"/>
              </svg>
            </a>
          </div>
        </nav>
      </div>

      <script is:inline>
        const btn = document.querySelector("[data-menu-btn]");
        const menu = document.querySelector("[data-menu]");
        if (btn && menu) {
          btn.addEventListener("click", () => {
            const open = menu.style.display === "block";
            menu.style.display = open ? "none" : "block";
            btn.setAttribute("aria-expanded", String(!open));
          });
        }
      </script>
    </header>

    <main class="wrap" style="padding: 28px 18px 80px;">
      <slot />
    </main>

    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>

    <script>
      function renderMermaid() {
        if (!window.mermaid) return;

        mermaid.initialize({
          startOnLoad: false,
          theme: "dark"
        });

        // Render all raw .mermaid blocks
        document.querySelectorAll(".mermaid").forEach((el, index) => {
          const graph = el.textContent.trim();
          el.innerHTML = "";
          mermaid.render("mermaid-" + index, graph)
            .then(({ svg }) => {
              el.innerHTML = svg;
            })
            .catch(err => console.error(err));
        });
      }

      document.addEventListener("DOMContentLoaded", renderMermaid);
      document.addEventListener("astro:page-load", renderMermaid);
    </script>

  </body>
</html>